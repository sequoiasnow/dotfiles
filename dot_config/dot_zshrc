# fi

# If we have fortune installed, use it
if command -v fortune &>/dev/null; then
  fortune
else
  echo "fortune not installed! That's so unfortunate!"
  echo
  echo "> Maybe try 'brew install fortune' :)"
  echo "  -- Sincerely, your past self"
fi


# Set the editor to helix
export EDITOR=hx

# Some common emacs aliases
alias ec="emacsclient"
alias e="emacs"

# Use the starship prompt
eval "$(starship init zsh)"
